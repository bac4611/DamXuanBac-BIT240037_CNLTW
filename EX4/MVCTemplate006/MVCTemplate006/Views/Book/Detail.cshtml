@model MVCTemplate006.Models.Book

@{
    ViewData["Title"] = "Chi Tiết Sách";
}

<div class="d-flex justify-content-end">
    <div class="card w-50">
        <h2 class="h5 mb-0">Chi Tiết Sách</h2>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Mã</dt>
            <dd class="col-sm-9">@Model.id</dd>

            <dt class="col-sm-3">Tên sách</dt>
            <dd class="col-sm-9">@Model.name</dd>

            <dt class="col-sm-3">Giá</dt>
            <dd class="col-sm-9">@Model.price.ToString("C")</dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-controller="Book" asp-action="Index" class="btn btn-secondary">Quay Lại</a>
    </div>
</div>
