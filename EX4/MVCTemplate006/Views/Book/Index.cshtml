@model IEnumerable<MVCTemplate006.Models.Book>

@{
    ViewData["Title"] = "Quản Lý Sách";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="mb-0">Quản Lý Sách</h2>
    <a asp-controller="Book" asp-action="Create" class="btn btn-primary">Thêm Sách</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
    <tr>
        <th scope="col">Mã</th>
        <th scope="col">Tên sách</th>
        <th scope="col">Giá</th>
        <th scope="col" class="text-end">Thao tác</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var book in Model)
    {
        <tr>
            <td>@book.id</td>
            <td>@book.name</td>
            <td>@book.price.ToString("C")</td>
            <td class="text-end">
                <a asp-controller="Book" asp-action="Detail" asp-route-id="@book.id" class="btn btn-sm btn-outline-secondary">Chi tiết</a>
            </td>
        </tr>
    }
    </tbody>
</table>
