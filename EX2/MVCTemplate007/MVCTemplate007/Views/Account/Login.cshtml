@model MVCTemplate007.Models.LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập hệ thống";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <!-- Thẻ Card tạo khung cho form đăng nhập -->
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body p-4 p-sm-5">
                    
                    <h3 class="card-title text-center mb-4 fw-bold text-primary">ĐĂNG NHẬP</h3>
                    
                    <!-- Hiển thị thông báo lỗi nếu đăng nhập thất bại -->
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger text-center py-2 mb-3" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.ErrorMessage
                        </div>
                    }

                    <form asp-action="Login" asp-controller="Account" method="post">
                        
                        <!-- Ô nhập Tài khoản -->
                        <div class="form-floating mb-3">
                            <input asp-for="UserName" class="form-control" id="floatingInput" placeholder="Tên đăng nhập" required />
                            <label for="floatingInput">Tên đăng nhập</label>
                        </div>
                        
                        <!-- Ô nhập Mật khẩu -->
                        <div class="form-floating mb-3">
                            <input asp-for="Password" type="password" class="form-control" id="floatingPassword" placeholder="Mật khẩu" required />
                            <label for="floatingPassword">Mật khẩu</label>
                        </div>

                        <!-- Checkbox ghi nhớ đăng nhập (bổ sung cho giao diện đẹp) -->
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="rememberMe">
                            <label class="form-check-label text-muted" for="rememberMe">
                                Ghi nhớ đăng nhập
                            </label>
                        </div>

                        <!-- Nút Đăng nhập -->
                        <div class="d-grid">
                            <button class="btn btn-primary btn-login text-uppercase fw-bold py-2" type="submit">
                                Đăng nhập
                            </button>
                        </div>
                        
                    </form>
                    
                </div>
            </div>
        </div>
    </div>
</div>