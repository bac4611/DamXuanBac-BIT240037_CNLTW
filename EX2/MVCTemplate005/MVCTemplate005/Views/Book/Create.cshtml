@model MVCTemplate005.Models.Book

<div class="container mt-5" style="max-width: 500px;">
    <h2 class="text-center mb-4">Thêm Sách Mới</h2>

    @if (ViewBag.Message != null)
    {
        <div class="alert alert-@ViewBag.Status" role="alert">
            @ViewBag.Message
        </div>
    }

    <form asp-controller="Book" asp-action="Create" method="post">
        <div class="mb-3">
            <label asp-for="name" class="form-label">Tên sách</label>
            <input asp-for="name" class="form-control" placeholder="Nhập tên cuốn sách..." />
            <span asp-validation-for="name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="price" class="form-label">Giá sách</label>
            <input asp-for="price" type="number" step="0.01" class="form-control" placeholder="Nhập giá tiền..." />
            <span asp-validation-for="price" class="text-danger"></span>
        </div>
        
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary flex-grow-1">Lưu Lại</button>
            <a asp-controller="Book" asp-action="Index" class="btn btn-secondary">Quay Lại</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
